# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
env/
.env/
.venv/

# Proprietary Data (NEVER commit SCADA data to GitHub!)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Excel temp lock files (created when file is open in Excel)
~$*.xlsx
~$*.xls

# Local Artifacts & Outputs
outputs/
wandb/
*.pt
*.pth
*.onnx

# IDEs and OS files
.idea/
.vscode/
.DS_Store
*.swp

# Jupyter Notebooks
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# Frontend (documentation React app)
documentation/node_modules/
documentation/dist/
documentation/.vite/